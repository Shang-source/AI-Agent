PORT=3000
DEBUG=false
HTTPS_PROXY=http://localhost:7890

# Public base URL used by payment providers to call back to this service.
# Example: https://api.example.com
PAYMENT_NOTIFY_BASE_URL=

# Development only. Enables a mock payment provider for local end-to-end tests.
MOCK_PAYMENT_ENABLED=false

# Alipay page pay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# Optional, defaults to https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=

# WeChat Pay Native v3
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
